{
  "name": "tree-sitter-pawn",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Pawn v3 used by SA-MP/open.mp.",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "tree-sitter",
    "pawn",
    "samp",
    "open.mp",
    "parser"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "queries/**",
    "src/**",
    "LICENSE"
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "test:external:fetch": "bash test/external/fetch.sh",
    "test:external": "bash test/external/parse.sh",
    "test:external:list": "find .fixtures/pawn-projects -type f | sort",
    "check:external": "npm run test:external:fetch && npm run test:external",
    "parse": "tree-sitter parse",
    "check": "npm run generate && npm test",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run generate"
  },
  "devDependencies": {
    "tree-sitter-cli": "0.25.10"
  }
}