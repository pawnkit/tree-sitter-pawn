{
    "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
    "grammars": [
        {
            "name": "pawn",
            "camelcase": "Pawn",
            "title": "Pawn",
            "scope": "source.pawn",
            "file-types": [
                "pwn",
                "inc"
            ],
            "injection-regex": "^pawn$"
        }
    ],
    "metadata": {
        "version": "0.1.0",
        "license": "MIT",
        "description": "Tree-sitter grammar for classic Pawn v3 as used by SA-MP/open.mp"
    },
    "bindings": {
        "c": true,
        "go": true
    }
}